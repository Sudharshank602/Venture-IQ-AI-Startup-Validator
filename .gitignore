# ============================================================
# VentureIQ — .gitignore
# ============================================================

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ── Virtual Environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/
.virtualenv/
virtualenv/

# ── Distribution / Build ─────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
nosetests.xml
test-results/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── FAISS / Vector Store ─────────────────────────────────────
data/embeddings/*.index
data/embeddings/*.faiss
*.index
*.faiss

# ── Reports & Generated Files ────────────────────────────────
reports/
*.pdf
output/

# ── Jupyter Notebooks ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ── Docker ───────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── Streamlit ────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Mypy / Type Checking ─────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/